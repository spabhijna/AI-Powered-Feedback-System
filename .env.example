# =============================================================================
# Feedback System - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# LLM - Groq API  (required for AI analysis)
# Get your key at: https://console.groq.com
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Set to true to skip Groq and use local DistilBERT/BART models instead
# (requires ~1.8 GB model download on first run)
LOCAL_FALLBACK=false


# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite://feedback.db
# PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/feedback

# Allowed CORS origins - restrict in production
CORS_ORIGINS=*


# -----------------------------------------------------------------------------
# Streamlit Dashboard
# URL of the FastAPI backend that the dashboard connects to
# -----------------------------------------------------------------------------
API_BASE=http://localhost:8000


# -----------------------------------------------------------------------------
# Email Ingestion  (optional)
# Uses standard IMAP. For Gmail, create an App Password at:
# https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
EMAIL_HOST=imap.gmail.com
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-specific-password


# -----------------------------------------------------------------------------
# Scheduler  (optional)
# Set SCHEDULER_ENABLED=true to run scraping/email jobs automatically
# -----------------------------------------------------------------------------
SCHEDULER_ENABLED=false
EMAIL_POLL_MINUTES=30


# -----------------------------------------------------------------------------
# Google Play Store Scraping  (optional)
# Only active when SCHEDULER_ENABLED=true and PLAY_STORE_APP_ID is set
# -----------------------------------------------------------------------------
PLAY_STORE_APP_ID=com.example.yourapp
PLAY_STORE_COUNT=50
PLAY_STORE_SCRAPE_HOURS=6


# -----------------------------------------------------------------------------
# Apple App Store Scraping  (optional)
# Only active when SCHEDULER_ENABLED=true and APP_STORE_APP_NAME is set
# -----------------------------------------------------------------------------
APP_STORE_APP_NAME=YourAppName
APP_STORE_APP_ID=123456789
APP_STORE_COUNTRY=us
APP_STORE_COUNT=50
APP_STORE_SCRAPE_HOURS=6
